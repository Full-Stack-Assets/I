# /marketing/scripts

Below are all script files required for the marketing automation system.
Each file begins with a header comment indicating its filename.

============================================================
FILE: generate_all_marketing_assets.py
============================================================
import json, os
from jinja2 import Environment, FileSystemLoader

# Base directories
BASE = os.path.dirname(os.path.abspath(__file__)) + "/.."
TEMPLATES = BASE + "/templates"
OUTPUT = BASE + "/output"

env = Environment(loader=FileSystemLoader(TEMPLATES))

def render(template, ctx):
    return env.get_template(template).render(**ctx)

def ensure(path):
    if not os.path.exists(path):
        os.makedirs(path)

def main():
    with open(BASE + "/apps.json") as f:
        apps = json.load(f)

    channels = ["landing", "flippa", "gumroad", "reddit", "linkedin", "email"]
    for c in channels:
        ensure(f"{OUTPUT}/{c}")

    for app in apps:
        slug = app["slug"]

        for channel in channels:
            template = f"{channel}.md"
            out = render(template, app)
            with open(f"{OUTPUT}/{channel}/{slug}.md", "w") as f:
                f.write(out)

    print("All marketing assets generated.")

if __name__ == "__main__":
    main()

